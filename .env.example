# Back4App → App Settings → Security & Keys (use JavaScript key in the browser)
VITE_BACK4APP_APP_ID=paste_your_application_id
VITE_BACK4APP_JS_KEY=paste_your_javascript_key

# Default Parse server for Back4App (only change if you use a custom URL)
# VITE_BACK4APP_SERVER_URL=https://parseapi.back4app.com/

# Budgets, manual expenses, and goals sync to Parse class "UserFinance" (created on first save).
# If saves fail with permission errors, open Back4App → App → Database → Browser → UserFinance → Class Level Permissions
# and allow authenticated users to Create / Find / Get / Update (each row also uses an ACL so only the owner can access it).
#
# Household sharing uses classes Household, HouseholdFinance, HouseholdMember, HouseholdInvite, HouseholdJoinRequest
# (see README "Household budgets"). Optional Cloud Code: cloud/household-main.js — not used by the default client.

# Optional: overspending email notifications (no backend). Configure a webhook that sends an email (Zapier/Make/IFTTT).
# When any category crosses over-budget (spent >= cap), the app POSTs JSON to this URL.
# VITE_OVERSPEND_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
